{
  "name": "server",
  "version": "0.0.1",
  "description": "",
  "main": "app/main.ts",
  "type": "module",
  "keywords": [],
  "author": "",
  "license": "GORTH",
  "scripts": {
    "start": "node .express/app/index.js",
    "build": "tsc && tsc-alias",
    "clean": "rm -rf .express node_modules",
    "alias": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "render": "pnpm install && tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "tsx": "tsx watch app/index.ts",
    "dev": "nodemon || exit 0",
    "builder": "rimraf .express && npx tsc",
    "pull": "pnpm install",
    "env": "ts-node -r dotenv/config -r tsconfig-paths/register app/index.ts",
    "genalias": "prisma generate && pnpm run alias",
    "postinstallx": "tsc && tsc-alias && prisma generate",
    "postbuild": "prisma generate",
    "generated": "cp -R prisma/generated .express/prisma/generated",
    "watch": "nodemon --watch './**/*.ts' --exec 'ts-node' app/index.ts",
    "pack": "nodemon -r tsconfig-paths/register app/index.ts",
    "postinstall": "pnpm update gorth-base",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "@paypal/paypal-server-sdk": "^2.3.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@stripe/stripe-js": "^9.4.0",
    "@vercel/node": "^5.8.0",
    "body-parser": "^2.2.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.1",
    "express-session": "^1.19.0",
    "gorth-base": "github:goraria/gorth-base",
    "graphql": "^16.14.0",
    "graphql-tag": "^2.12.6",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "module-alias": "^2.3.4",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.7",
    "otplib": "^13.4.0",
    "pg": "^8.20.0",
    "picocolors": "^1.1.1",
    "pluralize": "^8.0.0",
    "postgres": "^3.4.9",
    "qrcode": "^1.5.4",
    "sequelize": "^6.37.8",
    "stripe": "^22.1.1",
    "tsconfig-paths": "^4.2.0"
  },
  "devDependencies": {
    "@types/body-parser": "^1.19.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.19.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/module-alias": "^2.0.4",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.7.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/pluralize": "^0.0.33",
    "@types/qrcode": "^1.5.6",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.3",
    "prisma": "^7.8.0",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "_moduleAliases": {
    "@": ".express"
  }
}
